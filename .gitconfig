# ==============================
# GIT CONFIG — afrijaldz/dotfiles
# ==============================

[user]
	name = Afrijal Dzuhri
	email = hi@afrijal.dev

# Machine-specific overrides go in ~/.gitconfig.local (not tracked in git),
# mirroring the ~/.zshrc.local pattern. Silently skipped if absent.
# Keep this last so local settings win.
[include]
	path = ~/.gitconfig.local
