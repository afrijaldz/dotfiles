# TPM plugin clones — di-install per-mesin lewat `prefix + I` (lihat bootstrap.sh),
# bukan di-commit. Tiap plugin punya .git sendiri, kalau ter-track jadi embedded repo.
.config/tmux/plugins/

# ~/.gitconfig is machine-local: `gh auth login` writes to it and it holds
# host-specific absolute paths. Listed here so it can't be re-added by accident.
.gitconfig
